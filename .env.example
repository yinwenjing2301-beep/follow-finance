# ============================================================
# follow-finance 环境变量
# 复制此文件为 ~/.follow-finance/.env 并填写
#
# 数据抓取（Twitter 推文）完全免费，不需要任何 API Key。
# 只有选择邮件或 Telegram 发送时才需要填以下 Key。
# ============================================================

# 邮件发送 API Key（仅选择邮件发送时需要）
# 申请地址：https://resend.com（免费套餐每天 100 封）
# RESEND_API_KEY=

# Telegram Bot Token（仅选择 Telegram 发送时需要）
# 通过 @BotFather 创建 bot 获得
# TELEGRAM_BOT_TOKEN=
